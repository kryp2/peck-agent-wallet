{
  "name": "bitcoin-agent-wallet",
  "version": "0.3.0",
  "description": "BRC-100 native wallet primitive for autonomous agents on BSV. Wraps @bsv/wallet-toolbox with OS-keychain identity storage, standard PeerPay funding via @bsv/message-box-client, and a broadcast() primitive for arbitrary Bitcoin Schema / locking scripts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "smoke": "tsx examples/smoke.ts"
  },
  "keywords": [
    "bsv",
    "bitcoin-sv",
    "brc-100",
    "brc-29",
    "brc-42",
    "agent",
    "autonomous",
    "wallet",
    "bitcoin-schema",
    "peerpay",
    "keychain",
    "messagebox"
  ],
  "author": "kryp2",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryp2/bitcoin-agent-wallet.git"
  },
  "bugs": {
    "url": "https://github.com/kryp2/bitcoin-agent-wallet/issues"
  },
  "homepage": "https://github.com/kryp2/bitcoin-agent-wallet#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bsv/message-box-client": "^2.1.0",
    "@bsv/sdk": "^2.0.13",
    "@bsv/wallet-toolbox": "^2.1.18",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "keytar": "^7.9.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
